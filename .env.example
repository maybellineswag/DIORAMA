# Copy this file to .env.local and fill in your real key.
# Get a Gemini API key at https://aistudio.google.com/apikey (starts with "AIza").
GEMINI_API_KEY=your-gemini-api-key-here

# Optional password gate for the deployed app. Leave blank to disable.
APP_PASSWORD=

# --- Free-tier tuning (optional) ---
# Vision model. Flash-Lite has the most generous free limits.
GEMINI_MODEL=gemini-2.5-flash-lite
# Minimum ms between API calls. Raise if you still hit 429s; lower to go faster.
GEMINI_MIN_INTERVAL_MS=4500
